# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
PORT=8800
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE (PRISMA)
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/twvinfast?schema=public"

# -----------------------------------------------------------------------------
# AUTHENTICATION (JWT)
# -----------------------------------------------------------------------------
# Use strong, random strings for secrets
JWT_ACCESS_SECRET="your_jwt_access_secret_key"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key"

# -----------------------------------------------------------------------------
# STRIPE INTEGRATION
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Checkout Redirect URLs
STRIPE_CHECKOUT_SUCCESS_URL="http://localhost:3000/billing/success?session_id={CHECKOUT_SESSION_ID}"
STRIPE_CHECKOUT_CANCEL_URL="http://localhost:3000/billing/cancel"

# Optional: Specific Stripe Price IDs (Used by Seeder)
# These should match the names of your plans in uppercase
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_STARTER_YEARLY="price_..."

# -----------------------------------------------------------------------------
# AI SERVICES (OPENAI)
# -----------------------------------------------------------------------------
OPENAI_API_KEY="sk-..."

# -----------------------------------------------------------------------------
# MAIL CONFIGURATION (IMAP/SMTP)
# -----------------------------------------------------------------------------
# Default credentials for system-wide mail synchronization
IMAP_USER="admin@example.com"
IMAP_PASS="your_password"
IMAP_HOST="imap.gmail.com"
IMAP_PORT=993

SMTP_USER="admin@example.com"
SMTP_PASS="your_password"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES / OTHER
# -----------------------------------------------------------------------------
# DigitalOcean Spaces or other S3-compatible storage (if used)
# DO_SPACES_KEY="..."
# DO_SPACES_SECRET="..."
# DO_SPACES_ENDPOINT="..."
# DO_SPACES_BUCKET="..."
